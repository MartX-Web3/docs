{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Echo Protocol",
  "colors": {
    "primary": "#00E57C",
    "light": "#00E57C",
    "dark": "#00B85E"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/logo-light.png",
    "dark": "/logo/logo-dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/echo-protocol/echo-mvp"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "http://localhost:3000"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/quickstart",
              "getting-started/onboarding"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core-concepts/eip-7702",
              "core-concepts/policy",
              "core-concepts/on-chain-enforcement"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/custom-protocols",
              "advanced/debugging"
            ]
          },
          {
            "group": "Roadmap",
            "pages": [
              "roadmap/overview"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "MCP Tools & Config",
            "pages": [
              "api-reference/mcp-tools",
              "api-reference/gateway-config",
              "api-reference/contract-addresses"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/echo-protocol/echo-mvp",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/echo-protocol",
          "icon": "discord"
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "mcp", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/echo_protocol",
      "github": "https://github.com/echo-protocol"
    }
  }
}
